    "# CODE CELL: Model training and setup code\n",
    "def Predicted_Hull_Integrity(row):\n",
    "    power = row['Reactor_Power']\n",
    "    ship_class = row['Ship_Class']\n",
    "    propulsion = row['Propulsion_Type_Clean']\n",
    "    overClocked = row['Possible_Overclocked_reactor']\n",
    "    sector = row['Sector']\n",
    "    cycle = row['Model_Cycle_Clean']\n",
    "\n",
    "    # 1: Extreme power = Critical\n",
    "    if overClocked:\n",
    "        return \"Critical\"\n",
    "    \n",
    "    # 2: cycle identifies Hull_Integrity\n",
    "    elif cycle is not None:\n",
    "        if cycle <= 7510:\n",
    "            return \"Critical\"\n",
    "        elif cycle <= 7516:\n",
    "            return \"Operational\"\n",
    "        else:\n",
    "            return \"Pristine\"\n",
    "        \n",
    "    # 3: there sector have high pristine\n",
    "    elif sector in [\"Nebula Industries\", \"Honda Systems\"]:\n",
    "        return \"Pristine\"\n",
    "\n",
    "    # 4: High wear combinations \n",
    "    elif ship_class == \"Shuttle\" and propulsion == \"Ion\":\n",
    "        return \"Critical\"\n",
    "    \n",
    "    elif propulsion == \"Ion\":\n",
    "        return \"Operational\"\n",
    "    \n",
    "    # 5: Low wear = pristine combinations\n",
    "    elif ship_class == \"Hauler\" and propulsion == \"Graviton\":\n",
    "        return \"Pristine\"\n",
    "    \n",
    "    elif propulsion == \"Graviton\":\n",
    "        return \"Operational\"\n",
    "    \n",
    "    # 6: Fallback \n",
    "    elif power is not None:\n",
    "        if power < 50:\n",
    "            return \"Pristine\"\n",
    "        else:\n",
    "            return \"Operational\"\n",
    "        \n",
    "    # 7: fallback of the model\n",
    "    return \"Operational\"\n",
    "\n",
    "df_merged['Predicted_Hull_Integrity'] = df_merged.apply(Predicted_Hull_Integrity, axis=1)"
   ]
